{
  "$schema": "https://railway.com/railway.json",
  "name": "pizza-app",
  "service": "pizza-app",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build",
    "output": "dist"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "npx vite preview --port $PORT --host"
  }
}